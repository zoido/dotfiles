#!/bin/bash

set -e

# Create cluster
vcluster create --driver docker vcluster \
    --set "controlPlane.distro.k8s.apiServer.extraArgs[0]=--service-account-jwks-uri=https://kubernetes.default.svc.cluster.local/openid/v1/jwks" \
    --set "experimental.docker.ports[0]=80:30080" \
    --set "experimental.docker.ports[1]=443:30443" \
    --set "experimental.docker.ports[2]=9000:30900"

helm repo update || true

# Install metrics server
helm repo add metrics-server https://kubernetes-sigs.github.io/metrics-server/

helm upgrade --install metrics-server metrics-server/metrics-server \
    --namespace metrics-server \
    --create-namespace \
    --set "args[0]=--kubelet-insecure-tls"


# Install traefik
helm repo add traefik https://helm.traefik.io/traefik

helm upgrade --install traefik traefik/traefik \
    --namespace traefik \
    --create-namespace \
    --values "${HOME}/.config/traefik-values.yaml"
