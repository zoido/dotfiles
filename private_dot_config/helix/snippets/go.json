{
  // Place your snippets for go here. Each snippet is defined under a snippet name and has a prefix, body and
  // description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
  // $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the
  // same ids are connected.
  // Example:
  // "Print to console": {
  // 	"prefix": "log",
  // 	"body": [
  // 		"console.log('$1');",
  // 		"$2"
  // 	],
  // 	"description": "Log output to console"
  // }
  "debug print": {
    "prefix": ["debug", "dbg"],
    "body": ["fmt.Fprintf(os.Stderr, \">>>>> %#v\\n\", $1)"],
    "description": "debug output to console"
  },
  "debug dump (godump)": {
    "prefix": ["dump","dmp"],
    "body": ["godump.Fdump(os.Stderr, $1)"],
    "description": "debug dump to console using godump"
  },
  "better table driven test": {
    "prefix": "tdt",
    "body": [
      "func Test$1(t *testing.T) {",
      "\ttype testCase struct {",
      "\t\t$2",
      "\t}",
      "",
      "\trun := func(t *testing.T, tc testCase) {",
      "\t\t// Given",
      "\t\t$3",
      "\t\t// When",
      "",
      "\t\t// Then",
      "\t}",
      "",
      "\ttestCases := map[string]testCase{",
      "\t\t\"\": {},",
      "\t}",
      "",
      "\tfor name, tc := range testCases {",
      "\t\tt.Run(name, func(t *testing.T) { run(t, tc) })",
      "\t}",
      "}"
    ],
    "description": "Custom better table-driven test"
  }
}
